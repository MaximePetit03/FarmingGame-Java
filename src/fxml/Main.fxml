<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="MainController">
   <children>
      <VBox alignment="TOP_CENTER" prefWidth="250.0" spacing="20.0" style="-fx-background-color: #2c3e50; -fx-padding: 20;">
         <children>
            <Label fx:id="moneyLabel" style="-fx-text-fill: #f1c40f; -fx-font-size: 18; -fx-font-weight: bold;" text="Richesse: 25 émeraudes" />

            <Separator style="-fx-background-color: #34495e;" />

            <Label style="-fx-text-fill: #bdc3c7; -fx-font-weight: bold;" text="--- STOCKS &amp; PRODUITS ---" />
            <Button fx:id="selectWheatBtn" onAction="#selectWheat" prefHeight="40" prefWidth="200" style="-fx-font-size: 14;" text="Blé: 0" />
            <Button fx:id="selectWaterMelonBtn" onAction="#selectWaterMelon" prefHeight="40" prefWidth="200" style="-fx-font-size: 14;" text="Pastèque: 0" />
            <Button fx:id="milkStockBtn" prefHeight="40" prefWidth="200" style="-fx-font-size: 14; -fx-base: #ecf0f1;" text="Lait: 0" />

            <Separator style="-fx-background-color: #34495e;" />

            <Label style="-fx-text-fill: #bdc3c7; -fx-font-weight: bold;" text="--- GRAINES ---" />
            <Button fx:id="wheatSeedsBtn" prefHeight="40" prefWidth="200" text="Graines Blé: 10" />
            <Button fx:id="waterMelonSeedsBtn" prefHeight="40" prefWidth="200" text="Graines Pastèque: 2" />
         </children>
      </VBox>

      <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" HBox.hgrow="ALWAYS">
         <tabs>
            <Tab text="Cultures">
               <content>
                  <fx:include fx:id="cultivableField" source="CultivableField.fxml" />
               </content>
            </Tab>
            <Tab text="Élevage">
               <content>
                  <fx:include fx:id="animalArea" source="Animal.fxml" />
               </content>
            </Tab>
            <Tab text="Marché">
               <content>
                  <fx:include fx:id="marketArea" source="Market.fxml" />
               </content>
            </Tab>
         </tabs>
      </TabPane>
   </children>
</HBox>