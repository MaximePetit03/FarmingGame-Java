<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="720.0" prefWidth="1080.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="MainController">

   <top>
      <HBox style="-fx-padding: 15; -fx-background-color: #2c3e50;">
         <children>
            <Label style="-fx-font-weight: bold; -fx-font-size: 20; -fx-text-fill: white;" text="FARM MY FARM" />
         </children>
      </HBox>
   </top>

   <left>
      <VBox prefWidth="250.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #ddd; -fx-border-width: 0 1 0 0;">
         <children>
            <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="INVENTAIRE" />
            <Separator />
            <Label fx:id="moneyLabel" style="-fx-font-size: 15; -fx-text-fill: #27ae60; -fx-font-weight: bold;" text="Richesse: 25" />
            <Separator />
            <Button fx:id="selectWheatBtn" maxWidth="Infinity" onAction="#selectWheat" text="Blé: 0" />
            <Button fx:id="wheatSeedsBtn" maxWidth="Infinity" onAction="#selectWheat" text="Graines Blé: 10" />
            <Separator />
            <Button fx:id="selectWaterMelonBtn" maxWidth="Infinity" onAction="#selectWaterMelon" text="Pastèque: 0" />
            <Button fx:id="waterMelonSeedsBtn" maxWidth="Infinity" onAction="#selectWaterMelon" text="Graines Pastèque: 2" />
         </children>
      </VBox>
   </left>

   <center>
      <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">
         <tabs>
            <Tab text="Cultures">
               <content>
                  <StackPane><fx:include fx:id="cultivableField" source="CultivableField.fxml" /></StackPane>
               </content>
            </Tab>
            <Tab text="Élevage">
               <content>
                  <StackPane><fx:include fx:id="animalArea" source="Animal.fxml" /></StackPane>
               </content>
            </Tab>
            <Tab text="Marché">
               <content>
                  <StackPane><fx:include fx:id="marketArea" source="Market.fxml" /></StackPane>
               </content>
            </Tab>
         </tabs>
      </TabPane>
   </center>
</BorderPane>