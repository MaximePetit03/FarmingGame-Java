<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-padding: 30; -fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="MarketController">
    <children>
        <Label style="-fx-font-weight: bold; -fx-font-size: 24;" text="LE MARCHÉ" />

        <HBox alignment="CENTER" spacing="15">
            <children>
                <VBox spacing="10" alignment="CENTER">
                    <Label text="GRAINES" style="-fx-font-weight: bold;" />
                    <Button onAction="#selectWheatSeed" text="Blé (5)" prefWidth="120" />
                    <Button onAction="#selectWaterMelonSeed" text="Pastèque (15)" prefWidth="120" />
                </VBox>

                <VBox spacing="10" alignment="CENTER">
                    <Label text="ANIMAUX" style="-fx-font-weight: bold;" />
                    <Button onAction="#selectCow" text="Vache (150)" prefWidth="120" />
                </VBox>

                <VBox spacing="10" alignment="CENTER">
                    <Label text="ALIMENTS" style="-fx-font-weight: bold;" />
                    <Button onAction="#selectWheatFood" text="Blé (10)" prefWidth="120" />
                    <Button onAction="#selectWaterMelonFood" text="Pastèque (25)" prefWidth="120" />
                </VBox>
            </children>
        </HBox>

        <VBox alignment="CENTER" maxWidth="300" spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #ccc; -fx-border-radius: 10; -fx-background-radius: 10;">
            <children>
                <Label fx:id="itemNameLabel" style="-fx-font-size: 18; -fx-font-weight: bold;" text="Choisir un produit" />
                <Label fx:id="totalPriceLabel" style="-fx-font-size: 20; -fx-text-fill: #27ae60; -fx-font-weight: bold;" text="0 éme." />

                <HBox alignment="CENTER" spacing="15">
                    <children>
                        <Button onAction="#minusQuantity" text="-" prefWidth="35" />
                        <Label fx:id="quantityLabel" style="-fx-font-size: 18;" text="1" />
                        <Button onAction="#plusQuantity" text="+" prefWidth="35" />
                    </children>
                </HBox>

                <HBox alignment="CENTER" spacing="10">
                    <children>
                        <Button onAction="#confirmPurchase" prefWidth="100" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="ACHETER" />
                        <Button onAction="#confirmSale" prefWidth="100" style="-fx-background-color: #e67e22; -fx-text-fill: white;" text="VENDRE" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>