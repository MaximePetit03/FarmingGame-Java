<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #F5F5DC; -fx-padding: 30;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="MarketController">
    <children>
        <Label style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #5D4037;" text="LE MARCHÉ" />

        <GridPane alignment="CENTER" hgap="15" vgap="15">
            <children>
                <Button onAction="#selectWheatSeed" prefHeight="45" prefWidth="160" style="-fx-base: #f1c40f; -fx-font-weight: bold;" text="Graines de Blé" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Button fx:id="selectWaterMelonBtn" onAction="#selectWaterMelonSeed" prefHeight="45" prefWidth="160" style="-fx-base: #f1c40f; -fx-font-weight: bold;" text="Graines Pastèque" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Button onAction="#selectWheatFood" prefHeight="45" prefWidth="160" style="-fx-base: #e67e22; -fx-font-weight: bold;" text="Blé" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <Button onAction="#selectWaterMelonFood" prefHeight="45" prefWidth="160" style="-fx-base: #e67e22; -fx-font-weight: bold;" text="Pastèque" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Button fx:id="selectCowBtn" onAction="#selectCow" prefHeight="45" prefWidth="160" style="-fx-base: #95a5a6; -fx-font-weight: bold;" text="Vache" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <Button onAction="#selectMilk" prefHeight="45" prefWidth="160" style="-fx-base: #ecf0f1; -fx-font-weight: bold;" text="Lait" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Button fx:id="selectChickenBtn" onAction="#selectChicken" prefHeight="45" prefWidth="160" style="-fx-base: #f39c12; -fx-font-weight: bold;" text="Poulet" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <Button onAction="#selectEgg" prefHeight="45" prefWidth="160" style="-fx-base: #ffffff; -fx-font-weight: bold;" text="Oeuf" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Button fx:id="selectGoldenChickenBtn" onAction="#selectGoldenChicken" prefHeight="45" prefWidth="160" style="-fx-base: #f1c40f; -fx-font-weight: bold;" text="Poulet Doré" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <Button onAction="#selectGoldenEgg" prefHeight="45" prefWidth="160" style="-fx-base: #FFD700; -fx-font-weight: bold;" text="Oeuf Doré" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            </children>
        </GridPane>

        <Label fx:id="itemNameLabel" style="-fx-font-size: 20; -fx-font-style: italic; -fx-text-fill: #7f8c8d;" text="Sélectionnez un produit" />

        <HBox alignment="CENTER" spacing="40">
            <children>
                <VBox alignment="CENTER" spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-border-color: #27ae60; -fx-border-width: 2; -fx-border-radius: 15;">
                    <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="ACHETER" />
                    <HBox alignment="CENTER" spacing="15">
                        <Button onAction="#minusBuyQuantity" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-background-radius: 50; -fx-min-width: 35;" text="-" />
                        <Label fx:id="buyQuantityLabel" style="-fx-font-size: 22; -fx-font-weight: bold;" text="1" />
                        <Button onAction="#plusBuyQuantity" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-background-radius: 50; -fx-min-width: 35;" text="+" />
                    </HBox>
                    <Label fx:id="totalBuyPriceLabel" style="-fx-font-size: 18; -fx-font-weight: bold;" text="0 éme." />
                    <Button fx:id="confirmPurchaseBtn" onAction="#confirmPurchase" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="VALIDER ACHAT" />
                </VBox>

                <VBox alignment="CENTER" spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-border-color: #e74c3c; -fx-border-width: 2; -fx-border-radius: 15;">
                    <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" text="VENDRE" />
                    <HBox alignment="CENTER" spacing="15">
                        <Button onAction="#minusSellQuantity" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-background-radius: 50; -fx-min-width: 35;" text="-" />
                        <Label fx:id="sellQuantityLabel" style="-fx-font-size: 22; -fx-font-weight: bold;" text="1" />
                        <Button onAction="#plusSellQuantity" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-background-radius: 50; -fx-min-width: 35;" text="+" />
                    </HBox>
                    <Label fx:id="totalSellPriceLabel" style="-fx-font-size: 18; -fx-font-weight: bold;" text="0 éme." />
                    <Button onAction="#confirmSale" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="VALIDER VENTE" />
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>