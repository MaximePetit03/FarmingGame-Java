<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="25.0" style="-fx-background-color: #F5F5DC; -fx-padding: 30;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="MarketController">
    <children>
        <Label style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #5D4037;" text="LE MARCHÉ" />

        <GridPane alignment="CENTER" hgap="15" vgap="15">
            <children>
                <Button onAction="#selectWheatSeed" prefHeight="45" prefWidth="160" style="-fx-base: #f1c40f; -fx-font-weight: bold;" text="Graines de Blé" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Button onAction="#selectWaterMelonSeed" prefHeight="45" prefWidth="160" style="-fx-base: #f1c40f; -fx-font-weight: bold;" text="Graines Pastèque" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Button onAction="#selectWheatFood" prefHeight="45" prefWidth="160" style="-fx-base: #e67e22; -fx-font-weight: bold;" text="Blé (Récolte)" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <Button onAction="#selectWaterMelonFood" prefHeight="45" prefWidth="160" style="-fx-base: #e67e22; -fx-font-weight: bold;" text="Pastèque (Récolte)" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Button onAction="#selectCow" prefHeight="45" prefWidth="160" style="-fx-base: #95a5a6; -fx-font-weight: bold;" text="Acheter Vache" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <Button onAction="#selectMilk" prefHeight="45" prefWidth="160" style="-fx-base: #ecf0f1; -fx-font-weight: bold;" text="Vendre Lait" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </children>
        </GridPane>

        <VBox alignment="CENTER" maxWidth="400" spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #D7CCC8; -fx-border-width: 2; -fx-border-radius: 15;">
            <children>
                <Label fx:id="itemNameLabel" style="-fx-font-size: 18; -fx-font-style: italic; -fx-text-fill: #7f8c8d;" text="Sélectionnez un produit" />

                <HBox alignment="CENTER" spacing="25">
                    <Button onAction="#minusQuantity" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-background-radius: 50; -fx-min-width: 45; -fx-min-height: 45;" text="-" />
                    <Label fx:id="quantityLabel" style="-fx-font-size: 28; -fx-font-weight: bold;" text="1" />
                    <Button onAction="#plusQuantity" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-background-radius: 50; -fx-min-width: 45; -fx-min-height: 45;" text="+" />
                </HBox>

                <Label fx:id="totalPriceLabel" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="0 émeraudes" />
            </children>
        </VBox>

        <HBox alignment="CENTER" spacing="30">
            <Button onAction="#confirmPurchase" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold; -fx-padding: 12 40; -fx-background-radius: 8;" text="ACHETER" />
            <Button onAction="#confirmSale" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold; -fx-padding: 12 40; -fx-background-radius: 8;" text="VENDRE" />
        </HBox>
    </children>
</VBox>